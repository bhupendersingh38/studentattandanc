{
  "name": "attendx-ai",
  "version": "1.0.0",
  "description": "AI-powered Smart Attendance & Campus Intelligence System",
  "private": true,
  "workspaces": [
    "frontend",
    "mobile"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:ai\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn main:app --reload",
    "dev:ai": "cd ai-engine && python main.py",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && python -m build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && pytest",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "setup": "npm run setup:frontend && npm run setup:backend && npm run setup:mobile",
    "setup:frontend": "cd frontend && npm install",
    "setup:backend": "cd backend && pip install -r requirements.txt",
    "setup:mobile": "cd mobile && npm install",
    "lint": "npm run lint:frontend",
    "lint:frontend": "cd frontend && npm run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/attendx-ai.git"
  },
  "keywords": [
    "ai",
    "face-recognition",
    "attendance",
    "machine-learning",
    "computer-vision",
    "education",
    "campus-management"
  ],
  "author": "Your Name",
  "license": "MIT"
}
